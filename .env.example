# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
# On Vercel, set these in Project Settings → Environment Variables.

# ─── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── Twilio ───────────────────────────────────────────────────────────────
# Twilio Console homepage (Account Info panel)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
# Phone Numbers → Manage → Active numbers, in E.164 (no spaces, no hyphens)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── App ──────────────────────────────────────────────────────────────────
# The public origin where this app is hosted. Used by the Twilio webhook for
# signature validation. On Vercel, set this to https://your-app.vercel.app
# (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKER_SESSION_SECRET=
